generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  password       String
  role           String    @default("CASHIER") // ADMIN, MANAGER, CASHIER
  phone          String?
  isActive       Boolean   @default(true)
  sessionVersion Int       @default(0)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  sales          Sale[]
  saleAdjustments SaleAdjustment[]
  stockMovements StockMovement[]
  shifts         Shift[]
  cashDrawerMovements CashDrawerMovement[]
  expenses       Expense[]
}

model Category {
  id          String   @id @default(cuid())
  name        String
  nameMm      String?
  description String?
  slug        String   @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  products Product[]
}

model Product {
  id                String   @id @default(cuid())
  name              String
  nameMm            String?
  sku               String   @unique
  barcode           String?  @unique
  categoryId        String
  costPrice         Float    @default(0)
  sellingPrice      Float    @default(0)
  stockQuantity     Int      @default(0)
  lowStockThreshold Int      @default(10)
  unit              String   @default("pcs") // pcs, kg, liter, pack, box
  imageUrl          String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  category       Category        @relation(fields: [categoryId], references: [id])
  saleItems      SaleItem[]
  stockMovements StockMovement[]
}

model Customer {
  id             String   @id @default(cuid())
  name           String
  phone          String?  @unique
  email          String?
  address        String?
  totalPurchases Float    @default(0)
  loyaltyPoints  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sales Sale[]
}

model Sale {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  clientSaleId  String?  @unique
  customerId    String?
  userId        String
  subtotal      Float    @default(0)
  discountAmount Float   @default(0)
  taxAmount     Float    @default(0)
  totalAmount   Float    @default(0)
  paidAmount    Float    @default(0)
  changeAmount  Float    @default(0)
  paymentMethod String   @default("CASH") // CASH, CARD, MOBILE_BANKING, CREDIT
  paymentStatus  String   @default("PAID") // PAID, PENDING, FAILED, REVERSED
  paymentReference String?
  paymentProviderResponse String?
  status        String   @default("COMPLETED") // COMPLETED, REFUNDED, VOIDED
  notes         String?
  createdAt     DateTime @default(now())

  customer       Customer?       @relation(fields: [customerId], references: [id])
  user           User            @relation(fields: [userId], references: [id])
  items          SaleItem[]
  stockMovements StockMovement[]
  adjustments    SaleAdjustment[]
  cashDrawerMovements CashDrawerMovement[]
}

model SaleAdjustment {
  id                    String   @id @default(cuid())
  saleId                String
  approverUserId        String
  type                  String   // REFUND, VOID
  reason                String
  amount                Decimal  @default(0) @db.Decimal(18, 2)
  paymentMethod         String
  paymentReversalStatus String   @default("PENDING") // PENDING, COMPLETED, FAILED, NOT_REQUIRED
  createdAt             DateTime @default(now())

  sale     Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  approver User @relation(fields: [approverUserId], references: [id])

  @@index([saleId])
  @@index([approverUserId])
}

model SaleItem {
  id        String @id @default(cuid())
  saleId    String
  productId String
  quantity  Int    @default(1)
  unitPrice Float  @default(0)
  costPrice Float  @default(0) // Historical cost at time of sale
  discount  Float  @default(0)
  total     Float  @default(0)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model StockMovement {
  id            String   @id @default(cuid())
  productId     String
  userId        String
  saleId        String?  // Link to sale for OUT/RETURN movements
  quantity      Int
  type          String   // IN, OUT, ADJUSTMENT, RETURN
  reason        String?
  previousStock Int
  newStock      Int
  createdAt     DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  sale    Sale?   @relation(fields: [saleId], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  category    String
  amount      Float
  description String?
  userId      String
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  cashDrawerMovements CashDrawerMovement[]
}

model Shift {
  id             String   @id @default(cuid())
  userId         String
  openingCash    Decimal  @default(0) @db.Decimal(18, 2)
  closingCash    Decimal? @db.Decimal(18, 2)
  expectedCash   Decimal? @db.Decimal(18, 2)
  actualCash     Decimal? @db.Decimal(18, 2)
  variance       Decimal? @db.Decimal(18, 2)
  status         String   @default("OPEN") // OPEN, CLOSED
  openedAt       DateTime @default(now())
  closedAt       DateTime?
  notes          String?

  user User @relation(fields: [userId], references: [id])
  cashDrawerMovements CashDrawerMovement[]

  @@index([userId, status])
}

model CashDrawerMovement {
  id        String   @id @default(cuid())
  shiftId   String?
  saleId    String?
  expenseId String?
  userId    String
  type      String   // OPENING, CASH_SALE, REFUND, VOID, PAID_IN, PAID_OUT, CLOSING
  amount    Decimal  @db.Decimal(18, 2)
  reason    String?
  createdAt DateTime @default(now())

  shift   Shift?   @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  sale    Sale?    @relation(fields: [saleId], references: [id], onDelete: SetNull)
  expense Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  user    User     @relation(fields: [userId], references: [id])

  @@index([shiftId])
  @@index([saleId])
  @@index([expenseId])
  @@index([userId])
  @@index([type])
}

model Settings {
  id            String  @id @default("default")
  businessName  String  @default("ShwePOS")
  businessNameMm String? @default("ရွှေPOS")
  address       String?
  phone         String?
  email         String?
  taxRate       Float   @default(0)
  currencySymbol String @default("K")
  logo          String?
  receiptFooter String?
}

model InvoiceCounter {
  date    String @id // YYYYMMDD format
  counter Int    @default(0)
}
